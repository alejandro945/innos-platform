# ---------------------------------------------------------------------------
# INOOS Platform — environment variables
# Copy to .env.local (Next.js) and .env (Prisma CLI). Never commit real values.
# ---------------------------------------------------------------------------

# Postgres (Neon) — needs pgvector. Use the pooled URL for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) URL for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-with: openssl rand -base64 32"
# Microsoft Entra ID (Azure AD) app registration
AUTH_MICROSOFT_ENTRA_ID_ID="your-app-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-app-client-secret"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0"

# Anthropic (Claude) — homologation agent
ANTHROPIC_API_KEY="sk-ant-..."

# Embeddings provider (candidate retrieval). Set the one you use.
# OPENAI_API_KEY="sk-..."   # if using OpenAI embeddings
EMBEDDINGS_MODEL="text-embedding-3-small"

# Inngest (durable jobs)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Vercel Blob (raw provider files)
BLOB_READ_WRITE_TOKEN=""

# App
NEXT_PUBLIC_APP_NAME="INOOS · Comparador de Tarifas"
