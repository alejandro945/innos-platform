# ---------------------------------------------------------------------------
# INOOS Platform — environment variables
# Copy to .env.local (Next.js) and .env (Prisma CLI). Never commit real values.
# ---------------------------------------------------------------------------

# --- Database --------------------------------------------------------------
# Local (docker compose): postgresql://inoos:inoos@localhost:5432/inoos
# Production (Neon): use the pooled URL for DATABASE_URL, direct for DIRECT_URL.
DATABASE_URL="postgresql://inoos:inoos@localhost:5432/inoos"
DIRECT_URL="postgresql://inoos:inoos@localhost:5432/inoos"

# --- Auth.js / Microsoft Entra ID ------------------------------------------
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_MICROSOFT_ENTRA_ID_ID="your-app-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-app-client-secret"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0"

# ===========================================================================
# AI providers — choose ONE setup. Without any, the app uses lexical fallback.
# ===========================================================================

# --- Option A: Local with Ollama (docker compose) --------------------------
LLM_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="qwen2.5"
EMBEDDINGS_PROVIDER="ollama"
OLLAMA_EMBED_MODEL="nomic-embed-text"
EMBEDDING_DIMS="768"            # nomic-embed-text=768, mxbai-embed-large=1024

# --- Option B: Cloud (Anthropic + OpenAI) ----------------------------------
# LLM_PROVIDER="anthropic"
# ANTHROPIC_API_KEY="sk-ant-..."
# EMBEDDINGS_PROVIDER="openai"
# OPENAI_API_KEY="sk-..."
# EMBEDDINGS_MODEL="text-embedding-3-small"
# EMBEDDING_DIMS="1536"

# --- Jobs (optional): Inngest durable orchestration ------------------------
# Without these, normalization runs inline (fine for dev / small files).
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- File storage (optional): Vercel Blob ----------------------------------
# Without this, raw files aren't archived but parsing still works.
BLOB_READ_WRITE_TOKEN=""

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="INOOS · Comparador de Tarifas"
