# ---------------------------------------------------------------------------
# INOOS Platform — environment variables
# Copy to .env.local (Next.js) and .env (Prisma CLI). Never commit real values.
# ---------------------------------------------------------------------------

# --- Database --------------------------------------------------------------
# Local (docker compose): postgresql://inoos:inoos@localhost:5432/inoos
# Production (Neon): use the pooled URL for DATABASE_URL, direct for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.../DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.../DB?sslmode=require"

# --- Auth.js / Microsoft Entra ID ------------------------------------------
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_MICROSOFT_ENTRA_ID_ID="your-app-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-app-client-secret"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0"

# --- Local admin login (dev / no-SSO) --------------------------------------
# When both are set, a usuario/contraseña form appears on the login page and
# logs in a user with the ADMIN role. Leave empty in production to disable.
LOCAL_ADMIN_EMAIL="admin@inoos.local"
LOCAL_ADMIN_PASSWORD="cambiar-esta-clave"

# ===========================================================================
# AI providers — choose ONE setup. Without any, the app uses lexical fallback.
# ===========================================================================

# --- Option A: Ollama (local docker, or Ollama Cloud) ----------------------
LLM_PROVIDER="ollama"
# Local docker: http://localhost:11434   ·   Cloud: https://ollama.com
OLLAMA_BASE_URL="http://localhost:11434"
# Required for Ollama Cloud (and any token-protected proxy). Empty for local docker.
OLLAMA_API_KEY=""
OLLAMA_CHAT_MODEL="qwen2.5"
EMBEDDINGS_PROVIDER="ollama"
OLLAMA_EMBED_MODEL="nomic-embed-text"
EMBEDDING_DIMS="768"            # nomic-embed-text=768, mxbai-embed-large=1024

# --- Option B: Cloud (Anthropic + OpenAI) ----------------------------------
# LLM_PROVIDER="anthropic"
# ANTHROPIC_API_KEY="sk-ant-..."
# EMBEDDINGS_PROVIDER="openai"
# OPENAI_API_KEY="sk-..."
# EMBEDDINGS_MODEL="text-embedding-3-small"
# EMBEDDING_DIMS="1536"

# --- Jobs (optional): Inngest durable orchestration ------------------------
# Without these, normalization runs inline (fine for dev / small files).
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# Items processed per Inngest run before handing off to a fresh run. Default 400.
NORMALIZE_BATCH_SIZE="400"
# How many items to homologate concurrently within a run. Set to your Inngest
# plan's concurrent-step budget (free trial = 5). If you self-host Ollama, also
# set OLLAMA_NUM_PARALLEL >= this on the VM or the concurrent LLM calls queue.
NORMALIZE_CONCURRENCY="5"
# Text chunks processed per run when extracting CUPS changes from a
# resolution PDF, before handing off to a fresh run. Default 60.
REGULATORY_CHUNK_BATCH_SIZE="60"
# Canonical items verified per run against SISPRO before handing off to a
# fresh run, and the pause between each lookup (be polite to a gov't server).
SISPRO_VERIFY_BATCH_SIZE="30"
SISPRO_REQUEST_DELAY_MS="400"
SISPRO_TIMEOUT_MS="15000"

# --- File storage (optional): Vercel Blob ----------------------------------
# Without this, raw files aren't archived but parsing still works.
BLOB_READ_WRITE_TOKEN=""

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="INOOS · Comparador de Tarifas"
