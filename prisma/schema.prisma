// INOOS Platform — data model
// Identifiers in English (per project convention). UI copy is Spanish.
// Postgres + pgvector. Embeddings stored via the `vector` extension.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// ---------------------------------------------------------------------------
// Tenancy & identity
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  nit       String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  providers            Provider[]
  canonicalItems       CanonicalItem[]
  rateCards            RateCard[]
  procurementProcesses ProcurementProcess[]
  auditLogs            AuditLog[]
  regulatoryUpdates    RegulatoryUpdate[]
  sisproVerifications  SisproVerification[]
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum Role {
  ADMIN
  PROCUREMENT_ANALYST
  REVIEWER
  PROVIDER_MANAGER
  VIEWER
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  entraOid       String?      @unique // Microsoft Entra ID object id
  email          String       @unique
  name           String?
  image          String?
  status         UserStatus   @default(ACTIVE)
  roles          UserRole[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  reviews      ItemMapping[] @relation("MappingReviewer")
  uploads      ProcessUpload[]
  processes    ProcurementProcess[]
  regulatoryUpdatesCreated RegulatoryUpdate[]
  sisproVerificationsRun   SisproVerification[]

  @@index([organizationId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

// ---------------------------------------------------------------------------
// Providers
// ---------------------------------------------------------------------------

enum ProviderStatus {
  ACTIVE
  INACTIVE
}

model Provider {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  nit            String?
  contactName    String?
  contactEmail   String?
  status         ProviderStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id])
  providerItems ProviderItem[]
  rateCards     RateCard[]
  uploads       ProcessUpload[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Canonical catalog (the source of truth)
// ---------------------------------------------------------------------------

enum ItemKind {
  SERVICE
  MEDICATION
  DEVICE
  SUPPLY
}

model CanonicalItem {
  id              String   @id @default(cuid())
  organizationId  String
  kind            ItemKind @default(SERVICE)
  normativeCode   String? // CUPS SISPRO
  name            String
  description     String?
  includesFees    Boolean  @default(false)
  includesSupplies Boolean @default(false)
  isApproved      Boolean  @default(true) // false = AI-proposed, pending admin approval
  isActive        Boolean  @default(true) // false = retired (superseded/eliminated by a regulatory update)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  codes        CanonicalCode[]
  rateCards    RateCard[]
  mappings     ItemMapping[]
  embedding    ItemEmbedding?
  cupsChangesMatched CupsCodeChange[] @relation("CupsChangeMatched")
  cupsChangesCreated CupsCodeChange[] @relation("CupsChangeCreated")
  sisproResults      SisproVerificationResult[]

  @@index([organizationId, kind])
}

enum CodeSystem {
  CUPS
  CUM
  ATC
  IUM
  OTHER
}

model CanonicalCode {
  id              String     @id @default(cuid())
  canonicalItemId String
  system          CodeSystem
  code            String

  canonicalItem CanonicalItem @relation(fields: [canonicalItemId], references: [id], onDelete: Cascade)

  @@unique([canonicalItemId, system, code])
  @@index([system, code])
}

/// Vector embedding for candidate retrieval (pgvector).
/// The `vector` column is added via raw migration (Prisma lacks a native type).
model ItemEmbedding {
  canonicalItemId String        @id
  canonicalItem   CanonicalItem @relation(fields: [canonicalItemId], references: [id], onDelete: Cascade)
  // embedding   vector(1536)  -- defined in SQL migration
  updatedAt       DateTime      @updatedAt
}

// ---------------------------------------------------------------------------
// Rates (tarifas)
// ---------------------------------------------------------------------------

model RateCard {
  id              String    @id @default(cuid())
  organizationId  String
  canonicalItemId String
  providerId      String
  tariffSource    String? // e.g. "Tarifario A — Aliado 1"
  type            String    @default("PROPIA") // tariff type from the provider file (e.g. PROPIA, SOAT, ISS); PROPIA when not specified
  value           Decimal   @db.Decimal(14, 2)
  currency        String    @default("COP")
  unit            String?
  inclusions      String?
  exclusions      String?
  providerCode    String? // the provider's own reference code for this line, as it appears in their tariff file
  extra           Json? // unmapped columns from the provider's source file, {header: value}
  validFrom       DateTime
  validTo         DateTime?
  sourceUploadId  String?
  // The procurement process whose upload produced this rate (set when
  // promoted from a process; null for manually-entered rates). Kept as its
  // own FK — not just derived via sourceUpload — so the link survives even if
  // the upload is later deleted, and so the rate repository can be filtered
  // or displayed by originating process without an extra join.
  sourceProcessId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id])
  canonicalItem CanonicalItem       @relation(fields: [canonicalItemId], references: [id])
  provider      Provider            @relation(fields: [providerId], references: [id])
  sourceUpload  ProcessUpload?      @relation(fields: [sourceUploadId], references: [id])
  sourceProcess ProcurementProcess? @relation(fields: [sourceProcessId], references: [id], onDelete: SetNull)

  @@index([organizationId, canonicalItemId])
  @@index([providerId])
  @@index([validFrom, validTo])
  @@index([sourceProcessId])
}

// ---------------------------------------------------------------------------
// Procurement processes, uploads & raw provider items
// ---------------------------------------------------------------------------

enum ProcessStatus {
  DRAFT
  PROCESSING
  IN_REVIEW
  COMPLETED
  ARCHIVED
}

model ProcurementProcess {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  description    String?
  status         ProcessStatus @default(DRAFT)
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  createdBy    User            @relation(fields: [createdById], references: [id])
  uploads      ProcessUpload[]
  comparisons  Comparison[]
  rateCards    RateCard[]

  @@index([organizationId, status])
}

enum UploadStatus {
  UPLOADED
  PARSING
  MAPPING
  NORMALIZING
  PAUSED
  READY
  FAILED
}

model ProcessUpload {
  id            String       @id @default(cuid())
  processId     String
  providerId    String
  uploadedById  String
  fileName      String
  blobUrl       String
  status        UploadStatus @default(UPLOADED)
  columnMapping Json? // confirmed mapping: {name, code, price, unit, exclusions}
  rowCount      Int          @default(0)
  parsedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  process       ProcurementProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  provider      Provider           @relation(fields: [providerId], references: [id])
  uploadedBy    User               @relation(fields: [uploadedById], references: [id])
  providerItems ProviderItem[]
  rateCards     RateCard[]

  @@index([processId])
}

model ProviderItem {
  id         String  @id @default(cuid())
  uploadId   String
  providerId String
  rowNumber  Int
  rawName    String
  rawCode    String?
  rawUnit    String?
  rawPrice   Decimal? @db.Decimal(14, 2)
  rawType    String? // tariff type column from the source file, if mapped
  currency   String   @default("COP")
  inclusions String?
  exclusions String?
  extra      Json? // headers from the source file not mapped to a known field, {header: value}

  upload   ProcessUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  provider Provider      @relation(fields: [providerId], references: [id])
  mapping  ItemMapping?

  @@index([uploadId])
  @@index([providerId, rawName])
}

// ---------------------------------------------------------------------------
// Homologation (the learning asset)
// ---------------------------------------------------------------------------

enum MappingMethod {
  RULE
  VECTOR
  AI
  HUMAN
}

enum MappingStatus {
  AUTO_APPROVED
  PENDING_REVIEW
  APPROVED
  REJECTED
  NO_MATCH
}

model ItemMapping {
  id              String        @id @default(cuid())
  providerItemId  String        @unique
  canonicalItemId String?
  confidence      Float         @default(0)
  method          MappingMethod
  status          MappingStatus @default(PENDING_REVIEW)
  rationale       String?
  candidates      Json? // top retrieval candidates [{id,code,name,score}]
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  providerItem  ProviderItem   @relation(fields: [providerItemId], references: [id], onDelete: Cascade)
  canonicalItem CanonicalItem? @relation(fields: [canonicalItemId], references: [id])
  reviewedBy    User?          @relation("MappingReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([canonicalItemId])
}

// ---------------------------------------------------------------------------
// Comparison results
// ---------------------------------------------------------------------------

model Comparison {
  id          String   @id @default(cuid())
  processId   String
  generatedAt DateTime @default(now())
  summary     Json? // aggregate stats snapshot

  process ProcurementProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  lines   ComparisonLine[]

  @@index([processId])
}

model ComparisonLine {
  id              String   @id @default(cuid())
  comparisonId    String
  canonicalItemId String
  minValue        Decimal? @db.Decimal(14, 2)
  maxValue        Decimal? @db.Decimal(14, 2)
  avgValue        Decimal? @db.Decimal(14, 2)
  optionCount     Int      @default(0)
  bestProviderId  String?
  options         Json // [{providerId, value, exclusions, validFrom, validTo}]

  comparison Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  @@index([comparisonId])
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String // e.g. "mapping.approved", "rate.created"
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Regulatory updates (CUPS code changes from Ministerio de Salud resolutions)
// ---------------------------------------------------------------------------

enum RegulatoryUpdateStatus {
  EXTRACTING
  REVIEW
  APPLIED
  FAILED
}

model RegulatoryUpdate {
  id               String    @id @default(cuid())
  organizationId   String
  resolutionNumber String?
  resolutionDate   DateTime?
  title            String?
  sourceFileName   String
  sourceBlobUrl    String?
  status           RegulatoryUpdateStatus @default(EXTRACTING)
  chunksTotal      Int?
  chunksProcessed  Int       @default(0)
  extractedAt      DateTime?
  appliedAt        DateTime?
  appliedById      String?
  createdById      String
  createdAt        DateTime  @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  createdBy    User             @relation(fields: [createdById], references: [id])
  changes      CupsCodeChange[]

  @@index([organizationId, status])
}

enum CupsChangeStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

model CupsCodeChange {
  id                 String   @id @default(cuid())
  regulatoryUpdateId String
  oldCode            String
  newCode            String? // null = code eliminated, no replacement
  oldDescription     String?
  newDescription     String?
  note               String?
  status             CupsChangeStatus @default(PENDING)
  matchedItemId      String? // CanonicalItem in this org whose normativeCode = oldCode
  createdItemId      String? // new CanonicalItem created when applied (clone of matchedItem)

  regulatoryUpdate RegulatoryUpdate @relation(fields: [regulatoryUpdateId], references: [id], onDelete: Cascade)
  matchedItem      CanonicalItem?   @relation("CupsChangeMatched", fields: [matchedItemId], references: [id])
  createdItem      CanonicalItem?   @relation("CupsChangeCreated", fields: [createdItemId], references: [id])

  @@index([regulatoryUpdateId])
}

// ---------------------------------------------------------------------------
// SISPRO verification (best-effort check of loaded CUPS against the public
// SISPRO lookup — see src/lib/sispro.ts for caveats)
// ---------------------------------------------------------------------------

enum SisproVerificationStatus {
  RUNNING
  DONE
  FAILED
}

model SisproVerification {
  id             String   @id @default(cuid())
  organizationId String
  status         SisproVerificationStatus @default(RUNNING)
  runAt          DateTime @default(now())
  runById        String
  scannedCount   Int      @default(0)

  organization Organization               @relation(fields: [organizationId], references: [id])
  runBy        User                       @relation(fields: [runById], references: [id])
  results      SisproVerificationResult[]

  @@index([organizationId])
}

enum SisproMatchStatus {
  MISMATCH
  NOT_FOUND
  ERROR
}

model SisproVerificationResult {
  id              String   @id @default(cuid())
  verificationId  String
  canonicalItemId String
  normativeCode   String
  status          SisproMatchStatus // matches aren't stored, only exceptions
  sisproName      String?
  note            String?

  verification  SisproVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  canonicalItem CanonicalItem      @relation(fields: [canonicalItemId], references: [id], onDelete: Cascade)

  @@index([verificationId])
}
